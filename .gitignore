# Neon Tasks — .gitignore

# Dependencies
node_modules/
**/node_modules/

# Environment variables — NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
# Note: .env.production is committed since it only has the public API URL (no secrets)

# Build output
client/dist/
client/build/

# Widget build
widget/dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
